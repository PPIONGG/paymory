# Copy this file to `.env` and fill in your real values.
# .env is git-ignored — never commit real secrets.

# Local PostgreSQL — replace YOUR_POSTGRES_PASSWORD with your local postgres password
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/paymory?schema=public"

# API port
PORT=4000

# Secret used to sign login sessions (use a long random string in production)
SESSION_SECRET="change-me"

# Shared code required on the sign-up page so only the couple can register
SIGNUP_CODE="paymory-signup"
